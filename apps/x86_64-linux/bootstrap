#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/Code/my-dotfiles}"
DOTFILES_REPO_URL="${DOTFILES_REPO_URL:-}"

_print() {
  echo -e "$1"
}

_prompt() {
  local message="$1"
  local variable="$2"

  _print "$message"
  read -r "$variable"
}

if [ -d "$DOTFILES_DIR/.git" ]; then
  _print "${GREEN}Dotfiles repository already exists at $DOTFILES_DIR${NC}"
else
  if [ -z "$DOTFILES_REPO_URL" ]; then
    _prompt "${YELLOW}Please enter your dotfiles repository URL: ${NC}" DOTFILES_REPO_URL
  fi

  mkdir -p "$(dirname "$DOTFILES_DIR")"
  _print "${YELLOW}Cloning dotfiles into $DOTFILES_DIR...${NC}"
  git clone "$DOTFILES_REPO_URL" "$DOTFILES_DIR"
fi

_print "${GREEN}Dotfiles bootstrap complete.${NC}"
_print "${YELLOW}Next: run your normal flake switch from this repository so chezmoi can seed its config and apply the dotfiles.${NC}"
