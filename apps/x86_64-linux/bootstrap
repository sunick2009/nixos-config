#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/Code/my-dotfiles}"
DOTFILES_REPO_URL="${DOTFILES_REPO_URL:-https://github.com/sunick2009/my-dotfiles.git}"
DOTFILES_REPO_BRANCH="${DOTFILES_REPO_BRANCH:-feat/chezmoi-non-nix-migration}"

_print() {
  echo -e "$1"
}

if [ -d "$DOTFILES_DIR/.git" ]; then
  _print "${GREEN}Dotfiles repository already exists at $DOTFILES_DIR${NC}"
else
  mkdir -p "$(dirname "$DOTFILES_DIR")"
  _print "${YELLOW}Cloning dotfiles into $DOTFILES_DIR from ${DOTFILES_REPO_URL} (${DOTFILES_REPO_BRANCH})...${NC}"
  git clone --branch "$DOTFILES_REPO_BRANCH" --single-branch "$DOTFILES_REPO_URL" "$DOTFILES_DIR"
fi

_print "${GREEN}Dotfiles bootstrap complete.${NC}"
_print "${YELLOW}Next: run your normal flake switch from this repository so chezmoi can seed its config and apply the dotfiles.${NC}"
